# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# XML Generator specific
logs/*.log
output/*.xml
backup/*.xml
config/*.json

# But keep example outputs and documentation
!output/*_README.md
!output/*_stats.json
!output/*_report.json
!output/*_features.json

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
temp/
tmp/